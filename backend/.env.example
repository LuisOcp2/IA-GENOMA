# ========================================
# IA-GENOMA Backend - Variables de Entorno
# ========================================
# Copia este archivo a .env y llena tus valores
# NUNCA subas el archivo .env a GitHub

# --- LLMs ---
GROQ_API_KEY=your_groq_api_key_here
GOOGLE_AI_KEY=your_google_ai_key_here
CEREBRAS_API_KEY=your_cerebras_api_key_here
SAMBANOVA_API_KEY=your_sambanova_api_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Modelo Principal ---
# Opciones: groq, google, openrouter, sambanova
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
# Modelo alternativo liviano (usar si rate limit en llama-3.3-70b):
# LLM_MODEL=llama-3.1-8b-instant

# --- STT (Speech-to-Text) ---
# Whisper via Groq (gratuito y rapidísimo)
STT_PROVIDER=groq
STT_MODEL=whisper-large-v3

# --- TTS (Text-to-Speech) ---
# gtts = Google gratuito | edge-tts = Microsoft | elevenlabs = pago pero más natural
TTS_PROVIDER=gtts
TTS_VOICE=es-CO-SalomeNeural
# Voces colombianas: es-CO-SalomeNeural (mujer) | es-CO-GonzaloNeural (hombre)

# --- Google Calendar (OAuth2) ---
GOOGLE_CALENDAR_CREDENTIALS_FILE=credentials.json
GOOGLE_CALENDAR_TOKEN_FILE=token.json

# --- Servidor ---
HOST=0.0.0.0
PORT=8000
DEBUG=True

# --- Seguridad ---
# Token que tu app Android debe enviar en cada request
API_SECRET_TOKEN=genoma_secret_change_this_2026

# --- Agente ---
AGENT_NAME=GENOMA
AGENT_PERSONALITY=Eres GENOMA, el asistente personal de Luis. Eres inteligente, directo, hablas en español colombiano casual. Eres eficiente y proactivo.
MAX_CONVERSATION_HISTORY=20

# --- Android Local Server ---
# IP del celular en la red local (cámbiala por la IP de tu celular)
# Para encontrar la IP: Ajustes > WiFi > Red actual > detalles
# Formato: http://<IP_CELULAR>:5000/action
ANDROID_WEBHOOK_URL=http://10.0.147.XXX:5000/action
# Ejemplo Tailscale: ANDROID_WEBHOOK_URL=http://100.XX.XX.XX:5000/action
